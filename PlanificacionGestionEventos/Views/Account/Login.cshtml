@model PlanificacionGestionEventos.Models.LoginViewModel

@{
    Layout = null; // Keep a clean page for login (no sidebar)
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Iniciar sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background:#f5f7fa; }
        .login-card { width: 380px; border-radius: 12px; }
        .brand-title { color: #0f1c2e; font-weight:700; }
        .btn-primary {
            color: #fff;
            background-color: #1b6ec2;
            border-color: #1861ac;
        }
        .form-floating > .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(27,110,194,0.15);
        }
    </style>
</head>
<body>

    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="card login-card shadow-sm">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <h4 class="brand-title">Planificación y Gestión de Eventos</h4>
                    <p class="text-muted mb-0">Inicia sesión para continuar</p>
                </div>

                <form asp-action="Login" method="post" novalidate>
                    <input type="hidden" name="returnToken" value="@ViewData["ReturnToken"]" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" value="@(ViewData["Email"] ?? Model.Email)" class="form-control" id="inputEmail" placeholder="Correo electrónico" />
                        <label for="inputEmail">Correo electrónico</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" id="inputPassword" placeholder="Contraseña" />
                        <label for="inputPassword">Contraseña</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-2">Iniciar sesión</button>

                    <div class="d-flex justify-content-between small text-muted">
                        <a asp-controller="Usuarios" asp-action="Index">Volver</a>
                        <a asp-action="Register">¿No tienes cuenta? Regístrate</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }
</body>
</html>
