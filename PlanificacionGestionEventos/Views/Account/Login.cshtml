@model PlanificacionGestionEventos.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Iniciar sesión</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #020617);
            font-family: 'Segoe UI', sans-serif;
            color: #e2e8f0;
        }

        /* CONTENEDOR */
        .center-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* CARD PRO */
        .card-pro {
            background: rgba(30, 41, 59, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            animation: fadeIn 0.6s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h4 {
            text-align: center;
            font-weight: bold;
        }

        p {
            text-align: center;
            color: #94a3b8;
        }

        /* INPUTS */
        .form-control {
            background: #020617;
            border: 1px solid #334155;
            color: white;
            border-radius: 10px;
            padding: 12px;
        }

            .form-control:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 10px rgba(59,130,246,0.5);
                background: #020617;
                color: white;
            }

        .form-floating label {
            color: #94a3b8;
        }

        /* BOTÓN */
        .btn-pro {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            border: none;
            padding: 12px;
            border-radius: 10px;
            color: white;
            font-weight: 500;
            transition: 0.3s;
        }

            .btn-pro:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(59,130,246,0.4);
            }

        /* LINKS */
        a {
            color: #3b82f6;
            text-decoration: none;
        }

            a:hover {
                text-decoration: underline;
            }

    </style>
</head>

<body>

    <div class="center-container">

        <div class="card-pro">

            <h4>🔐 Iniciar sesión</h4>
            <p>Accede a tu cuenta para continuar</p>

            <form asp-action="Login" method="post" novalidate>

                <input type="hidden" name="returnToken" value="@ViewData["ReturnToken"]" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" value="@(ViewData["Email"] ?? Model.Email)" class="form-control" placeholder="Correo" />
                    <label>Correo electrónico</label>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Contraseña" id="passwordInput" />
                    <label>Contraseña</label>
                </div>

                <!-- 👁 Mostrar contraseña -->
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="showPass">
                    <label class="form-check-label" for="showPass">
                        Mostrar contraseña
                    </label>
                </div>

                <button type="submit" class="btn-pro w-100 mb-3">
                    🚀 Entrar
                </button>

                <div class="d-flex justify-content-between small">
                    <a asp-controller="Home" asp-action="Index">⬅ Volver</a>
                    <a asp-action="Register">Crear cuenta</a>
                </div>

            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const checkbox = document.getElementById("showPass");
            const password = document.getElementById("passwordInput");

            checkbox.addEventListener("change", function () {
                password.type = this.checked ? "text" : "password";
            });

        });
    </script>
</body>
</html>