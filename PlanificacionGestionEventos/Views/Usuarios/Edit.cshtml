@model PlanificacionGestionEventos.Models.UsuarioEditViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #0f172a, #020617);
        color: #e2e8f0;
        font-family: 'Segoe UI', sans-serif;
    }

    /* CONTENEDOR CENTRADO PRO */
    .center-container {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* CARD PRO */
    .card-pro {
        background: rgba(30, 41, 59, 0.8);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 30px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
        animation: fadeIn 0.6s ease;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    h4 {
        text-align: center;
        margin-bottom: 20px;
        font-weight: bold;
    }

    /* INPUTS PRO */
    .form-control {
        background: #020617;
        border: 1px solid #334155;
        color: white;
        border-radius: 10px;
        padding: 12px;
    }

        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 10px rgba(59,130,246,0.5);
            background: #020617;
            color: white;
        }

    /* LABEL */
    .form-floating label {
        color: #94a3b8;
    }

    /* BOTONES PRO */
    .btn-pro {
        padding: 10px 18px;
        border-radius: 8px;
        border: none;
        font-weight: 500;
        transition: 0.3s;
    }

    .btn-save {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(59,130,246,0.4);
        }

    .btn-cancel {
        background: #334155;
        color: white;
        text-decoration: none;
    }

        .btn-cancel:hover {
            background: #475569;
            transform: translateY(-2px);
        }

    /* INPUT ICON EFFECT (BONUS) */
    .form-floating {
        position: relative;
    }

</style>

<div class="center-container">

    <div class="card-pro">

        <h4>✏️ Editar usuario</h4>

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <input type="hidden" asp-for="UsuarioId" />

            <div class="form-floating mb-3">
                <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre completo" />
                <label>Nombre completo</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Correo electrónico" />
                <label>Email</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Telefono" class="form-control" placeholder="809-123-4567" maxlength="12" id="telefono" />
                <label>Teléfono</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" type="password" class="form-control" placeholder="Contraseña" />
                <label>Contraseña (opcional)</label>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirmar contraseña" />
                <label>Confirmar contraseña</label>
            </div>

            <div class="d-flex justify-content-between">

                <button type="submit" class="btn-pro btn-save">
                    💾 Guardar
                </button>

                <a asp-action="Index" class="btn-pro btn-cancel">
                    ⬅ Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('telefono').addEventListener('input', function (e) {
            let value = e.target.value.replace(/\D/g, '');

            if (value.length > 10) value = value.slice(0, 10);

            if (value.length > 6) {
                value = value.replace(/(\d{3})(\d{3})(\d{1,4})/, '$1-$2-$3');
            } else if (value.length > 3) {
                value = value.replace(/(\d{3})(\d{1,3})/, '$1-$2');
            }

            e.target.value = value;
        });
    </script>
}