@model IEnumerable<PlanificacionGestionEventos.Models.UsuarioListViewModel>

<style>
    body {
        background-color: #0f172a;
        color: #e2e8f0;
        font-family: 'Segoe UI', sans-serif;
    }

    .container {
        margin-top: 40px;
    }

    h2 {
        text-align: center;
        margin-bottom: 30px;
        font-weight: bold;
    }

    /* TABLA MODERNA */
    .table-modern {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 12px;
        background: #1e293b;
        box-shadow: 0 10px 25px rgba(0,0,0,0.4);
    }

        .table-modern thead {
            background: linear-gradient(90deg, #2563eb, #3b82f6);
            color: white;
        }

        .table-modern th {
            padding: 14px;
            text-align: center;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

        .table-modern td {
            padding: 14px;
            text-align: center;
            border-top: 1px solid #334155;
        }

        .table-modern tbody tr {
            transition: 0.3s;
        }

            .table-modern tbody tr:hover {
                background: #334155;
                transform: scale(1.01);
            }

    /* BOTONES */
    .btn-edit {
        background: #22c55e;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        margin-right: 5px;
        text-decoration: none; /* 🔥 QUITA LA LÍNEA */
        display: inline-block;
    }

        .btn-edit:hover {
            background: #16a34a;
            text-decoration: none; /* 🔥 por si acaso */
            color: white;
        }

    .btn-delete {
        background: #ef4444;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
    }

        .btn-delete:hover {
            background: #dc2626;
        }

    /* MODAL */
    .modal-content {
        background: #1e293b;
        color: white;
        border-radius: 12px;
    }

    .btn-close {
        filter: invert(1);
    }

</style>

<div class="container">

    <h2>👥 Gestión de Usuarios</h2>

    <table class="table-modern">

        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>

            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Usuario?.NombreCompleto ?? "Sin nombre")</td>
                        <td>@(item.Usuario?.Email ?? "Sin email")</td>
                        <td>
                        @(item.Usuario?.Telefono != null && item.Usuario.Telefono.Length == 10
                        ? item.Usuario.Telefono.Insert(3, "-").Insert(7, "-")
                        : item.Usuario?.Telefono ?? "-")
                        </td>
                        <td>@item.RoleName</td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Usuario?.UsuarioId" class="btn-edit">
                                ✏️Editar
                            </a>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>
</div>

<!-- MODAL -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">⚠ Confirmar eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="confirmDeleteMessage"></p>
            </div>

            <div class="modal-footer">
                <form asp-action="Delete" method="post" id="confirmDeleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="confirmDeleteId" />

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-danger">
                        Eliminar
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {

            var modal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
            var idInput = document.getElementById('confirmDeleteId');
            var message = document.getElementById('confirmDeleteMessage');

            document.querySelectorAll('.btn-delete-trigger').forEach(btn => {

                btn.addEventListener('click', () => {

                    var id = btn.getAttribute('data-id');
                    var name = btn.getAttribute('data-name');

                    idInput.value = id;
                    message.textContent = '¿Seguro que deseas eliminar a "' + name + '"?';

                    modal.show();
                });

            });

        })();
    </script>
}