@model IEnumerable<PlanificacionGestionEventos.Models.UsuarioListViewModel>

<div class="container">

    <h2>Gestión de Usuarios</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">
        Crear Usuario
    </a>

    <table class="table table-striped">

        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>

            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Usuario.NombreCompleto</td>

                        <td>@item.Usuario.Email</td>

                        <td>@item.Usuario.Telefono</td>

                        <td>@item.RoleName</td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Usuario.UsuarioId" class="btn btn-success btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Usuario.UsuarioId" class="btn btn-danger btn-sm">
                                Eliminar
                            </a>

                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>