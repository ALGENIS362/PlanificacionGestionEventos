@model PlanificacionGestionEventos.Models.Invitacion

<style>

    /* FONDO GENERAL */
    body {
        background-color: #0f172a;
    }

    /* CONTENEDOR */
    .container-invitados {
        padding: 30px;
    }

    /* TITULOS */
    .titulo {
        font-size: 28px;
        font-weight: bold;
        color: #f1f5f9;
    }

    .subtitulo {
        color: #94a3b8;
        margin-bottom: 20px;
    }

    /* CARD PRINCIPAL */
    .card-form {
        background: #1e293b;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.4);
        max-width: 500px;
        color: white;
    }

    /* FORM */
    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            font-weight: bold;
            display: block;
            margin-bottom: 6px;
            color: #e2e8f0;
        }

    /* INPUTS */
    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #334155;
        background-color: #0f172a;
        color: white;
    }

    /* BOTONES */
    .botones {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    .btn-guardar {
        background: #2563eb;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

        .btn-guardar:hover {
            background: #1d4ed8;
        }

    .btn-cancelar {
        background: #334155;
        padding: 10px 16px;
        border-radius: 6px;
        text-decoration: none;
        color: white;
    }

        .btn-cancelar:hover {
            background: #475569;
        }

    /* LISTA DE EVENTOS */
    #eventList {
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-height: 220px;
        overflow: auto;
        padding: 6px;
        border: 1px solid #334155;
        border-radius: 6px;
        background: #0f172a;
    }

    /* BOTONES EVENTOS */
    .event-item {
        background: #1e293b;
        color: white;
        border: 1px solid #334155;
        text-align: left;
    }

        .event-item:hover {
            background: #2563eb;
        }

</style>

<div class="container-invitados" style="display:flex;justify-content:center;align-items:center;min-height:60vh;">
    <div class="card-form" style="width:600px;">
        <div style="text-align:center;margin-bottom:12px;">
            <h2 class="titulo">Agregar Invitado</h2>
            <p class="subtitulo">Introduce el correo y selecciona el evento</p>
        </div>

        <form asp-controller="Invitacions" asp-action="Create" method="post" id="invForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Correo del Invitado</label>
                <input asp-for="CorreoInvitado" class="form-control" placeholder="correo@ejemplo.com" />
                <span asp-validation-for="CorreoInvitado" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Eventos</label>

                <div id="eventList">
                    @{
                        var eventos = ViewBag.EventosDetailed as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                        if (!eventos.Any())
                        {
                            <div class="text-warning">No hay eventos disponibles para este organizador.</div>
                        }
                        else
                        {
                            foreach (var ev in eventos)
                            {
                                <button type="button" class="btn event-item event-item" data-id="@ev.EventoId">
                                    <div style="font-weight:600;">@ev.Nombre</div>
                                    <div style="font-size:12px;color:#94a3b8;">
                                        @(((DateTime)ev.Fecha).ToString("dd/MM/yyyy") + " " + (ev.Hora ?? "") + " — " + (ev.Lugar ?? ""))
                                    </div>
                                </button>
                            }
                        }
                    }
                </div>

                <input type="hidden" asp-for="EventoId" id="EventoId" />
                <div class="mt-2">
                    <small>Evento seleccionado: <span id="selEvent">ninguno</span></small>
                </div>
            </div>

            <div class="form-group">
                <label>Estado</label>
                <input type="text" class="form-control" value="Pendiente" readonly />
            </div>

            <div class="botones" style="justify-content:center;">
                <button type="submit" class="btn-guardar" id="submitBtn">
                    Guardar
                </button>

                <a asp-action="Index" class="btn-cancelar">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            var items = document.querySelectorAll('.event-item');
            var hidden = document.getElementById('EventoId');
            var sel = document.getElementById('selEvent');
            var form = document.getElementById('invForm');

            items.forEach(function(b){
                b.addEventListener('click', function(){
                    items.forEach(function(x){
                        x.classList.remove('active');
                        x.style.background = '#1e293b';
                    });

                    b.classList.add('active');
                    b.style.background = '#2563eb';

                    var id = b.getAttribute('data-id');
                    hidden.value = id;
                    sel.textContent = b.textContent.trim();
                });
            });

            form.addEventListener('submit', function(e){
                var correo = document.querySelector('[name="CorreoInvitado"]').value.trim();
                var eventoId = hidden.value;

                if(!correo){
                    e.preventDefault();
                    alert('Ingrese el correo del invitado.');
                    return;
                }

                if(!eventoId){
                    e.preventDefault();
                    alert('Seleccione un evento.');
                    return;
                }
            });
        })();
    </script>
}