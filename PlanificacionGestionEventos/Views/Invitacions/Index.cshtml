@model IEnumerable<PlanificacionGestionEventos.Models.Invitacion>
@using PlanificacionGestionEventos.Models

<style>

    body {
        background: #0f172a;
        color: white;
    }
    .container-invitados {
        padding: 30px;
    }

    .modal-content {
        background: white;
        color: #1e293b;
    }

    .modal-body label {
        color: #334155;
    }

    .titulo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .btn-agregar {
        background: #f59e0b;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        font-weight: bold;
        text-decoration: none;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .card-stat {
        background: linear-gradient(145deg,#1e293b,#0f172a);
        padding: 20px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
        color: white;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 20px;
    }

    .icon-confirmado {
        background: #064e3b;
        color: #22c55e;
    }

    .icon-pendiente {
        background: #78350f;
        color: #f59e0b;
    }

    .icon-rechazado {
        background: #7f1d1d;
        color: #ef4444;
    }

    .numero {
        font-size: 28px;
        font-weight: bold;
    }

    .table-box {
        background: linear-gradient(145deg,#1e293b,#0f172a);
        border-radius: 15px;
        padding: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        color: white;
    }

    thead {
        background: #334155;
    }

    th {
        padding: 12px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 14px;
        border-top: 1px solid #334155;
    }

    .estado {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: bold;
    }

    .confirmado {
        background: #166534;
        color: #22c55e;
    }

    .pendiente {
        background: #78350f;
        color: #f59e0b;
    }

    .rechazado {
        background: #7f1d1d;
        color: #ef4444;
    }

    .sin-invitados {
        text-align: center;
        padding: 40px;
        color: #94a3b8;
    }

        .sin-invitados i {
            font-size: 50px;
            margin-bottom: 10px;
            display: block;
        }

    .btn-delete {
        background: #ef4444;
        border: none;
        padding: 6px 10px;
        border-radius: 6px;
        color: white;
        text-decoration: none;
    }
</style>

<div class="container-invitados">

    <div class="titulo">

        <div>
            <h2 class="text-3xl fw-bold">Invitados</h2>
            <p class="text-secondary">Gestiona las invitaciones de tus eventos</p>
        </div>

        <button class="btn-agregar"
                data-bs-toggle="modal"
                data-bs-target="#crearInvitadoModal">
            <i class="bi bi-person-plus"></i> Agregar Invitado

        </button>

    </div>

    <div class="cards">

        <div class="card-stat">

            <div class="icon-box icon-confirmado">
                <i class="bi bi-check-lg"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Confirmado)
                </div>
                <div>Confirmados</div>
            </div>

        </div>

        <div class="card-stat">

            <div class="icon-box icon-pendiente">
                <i class="bi bi-clock"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Pendiente)
                </div>
                <div>Pendientes</div>
            </div>

        </div>

        <div class="card-stat">

            <div class="icon-box icon-rechazado">
                <i class="bi bi-x-lg"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Rechazado)
                </div>
                <div>Rechazados</div>
            </div>

        </div>

    </div>

    <div class="table-box">

        <table>

            <thead>
                <tr>
                    <th>Invitado</th>
                    <th>Evento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Any())
                {

                    foreach (var item in Model)
                    {

                        <tr>

                            <td>@item.CorreoInvitado</td>

                            <td>@item.Evento?.Nombre</td>

                            <td>

                                @if (item.Estado == EstadoRSVP.Confirmado)
                                {
                                    <span class="estado confirmado">Confirmado</span>
                                }
                                else if (item.Estado == EstadoRSVP.Pendiente)
                                {
                                    <span class="estado pendiente">Pendiente</span>
                                }
                                else
                                {
                                    <span class="estado rechazado">Rechazado</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Delete"
                                   asp-route-id="@item.InvitacionId"
                                   class="btn-delete"
                                   onclick="return confirm('¿Eliminar esta invitación?');">
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {

                    <tr>
                        <td colspan="4">

                            <div class="sin-invitados">

                                <i class="bi bi-people"></i>
                                <h5>No hay invitados todavía</h5>
                                <p>Crea tu primera invitación</p>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL CREAR INVITADO -->
<div class="modal fade" id="crearInvitadoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">

            <!-- HEADER -->
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus-fill me-2"></i>
                    Nueva Invitación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body p-4">

                <form asp-action="Create" method="post">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-envelope me-1 text-primary"></i>
                            Correo del Invitado
                        </label>
                        <input name="CorreoInvitado" class="form-control rounded-3" placeholder="ejemplo@email.com" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-calendar-event me-1 text-success"></i>
                            Evento
                        </label>
                        <select name="EventoId" class="form-select rounded-3" asp-items="ViewBag.EventoId"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-activity me-1 text-warning"></i>
                            Estado
                        </label>
                        <select name="Estado" class="form-select rounded-3">
                            <option value="Pendiente">Pendiente</option>
                            <option value="Confirmado">Confirmado</option>
                            <option value="Rechazado">Rechazado</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>
                            Guardar Invitación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>