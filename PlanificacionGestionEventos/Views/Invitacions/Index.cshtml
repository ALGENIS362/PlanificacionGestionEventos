@model IEnumerable<PlanificacionGestionEventos.Models.Invitacion>
@using PlanificacionGestionEventos.Models

<style>

    body {
        background: #0f172a;
        color: white;
    }
    .container-invitados {
        padding: 30px;
    }

    .modal-content {
        background: white;
        color: #1e293b;
    }

    .modal-body label {
        color: #334155;
    }

    .titulo {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .btn-agregar {
        background: #f59e0b;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        font-weight: bold;
        text-decoration: none;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .card-stat {
        background: linear-gradient(145deg,#1e293b,#0f172a);
        padding: 20px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
        color: white;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 20px;
    }

    .icon-confirmado {
        background: #064e3b;
        color: #22c55e;
    }

    .icon-pendiente {
        background: #78350f;
        color: #f59e0b;
    }

    .icon-rechazado {
        background: #7f1d1d;
        color: #ef4444;
    }

    .numero {
        font-size: 28px;
        font-weight: bold;
    }

    .table-box {
        background: linear-gradient(145deg,#1e293b,#0f172a);
        border-radius: 15px;
        padding: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        color: white;
    }

    thead {
        background: #334155;
    }

    th {
        padding: 12px;
        text-align: left;
        font-size: 14px;
    }

    td {
        padding: 14px;
        border-top: 1px solid #334155;
    }

    .estado {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: bold;
    }

    .confirmado {
        background: #166534;
        color: #22c55e;
    }

    .pendiente {
        background: #78350f;
        color: #f59e0b;
    }

    .rechazado {
        background: #7f1d1d;
        color: #ef4444;
    }

    .sin-invitados {
        text-align: center;
        padding: 40px;
        color: #94a3b8;
    }

        .sin-invitados i {
            font-size: 50px;
            margin-bottom: 10px;
            display: block;
        }

    .btn-delete {
        background: #ef4444;
        border: none;
        padding: 6px 10px;
        border-radius: 6px;
        color: white;
        text-decoration: none;
    }
</style>

<div class="container-invitados">

    <div class="titulo">

        <div>
            <h2 class="text-3xl fw-bold">Invitados</h2>
            <p class="text-secondary">Gestiona las invitaciones de tus eventos</p>
        </div>

        <a asp-action="Create" class="btn-agregar">
            <i class="bi bi-person-plus"></i> Agregar Invitado
        </a>

    </div>

    <div class="cards">

        <div class="card-stat">

            <div class="icon-box icon-confirmado">
                <i class="bi bi-check-lg"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Confirmado)
                </div>
                <div>Confirmados</div>
            </div>

        </div>

        <div class="card-stat">

            <div class="icon-box icon-pendiente">
                <i class="bi bi-clock"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Pendiente)
                </div>
                <div>Pendientes</div>
            </div>

        </div>

        <div class="card-stat">

            <div class="icon-box icon-rechazado">
                <i class="bi bi-x-lg"></i>
            </div>

            <div>
                <div class="numero">
                    @Model.Count(i => i.Estado == EstadoRSVP.Rechazado)
                </div>
                <div>Rechazados</div>
            </div>

        </div>

    </div>

    <div class="table-box">

        <table>

            <thead>
                <tr>
                    <th>Invitado</th>
                    <th>Evento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Any())
                {

                    foreach (var item in Model)
                    {

                        <tr>

                            <td>@item.CorreoInvitado</td>

                            <td>@item.Evento?.Nombre</td>

                            <td>

                                @if (item.Estado == EstadoRSVP.Confirmado)
                                {
                                    <span class="estado confirmado">Confirmado</span>
                                }
                                else if (item.Estado == EstadoRSVP.Pendiente)
                                {
                                    <span class="estado pendiente">Pendiente</span>
                                }
                                else
                                {
                                    <span class="estado rechazado">Rechazado</span>
                                }
                            </td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@item.InvitacionId" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete" onclick="return confirm('¿Eliminar esta invitación?');">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {

                    <tr>
                        <td colspan="4">

                            <div class="sin-invitados">

                                <i class="bi bi-people"></i>
                                <h5>No hay invitados todavía</h5>
                                <p>Crea tu primera invitación</p>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Removed inline modal to navigate to a dedicated Create page -->
