<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -Planificación y Gestión de Eventos</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <style>

        body{
        display:flex;
        margin:0;
        }

        .sidebar{
        width:240px;
        height:100vh;
        background:#0f1c2e;
        color:white;
        padding:20px;
        }

        .sidebar h4{
        color:#f59e0b;
        margin-bottom:5px;
        }

        .sidebar p{
        font-size:12px;
        color:#b8c1d1;
        margin-bottom:30px;
        }

        .menu{
        list-style:none;
        padding:0;
        }

        .menu li{
        margin-bottom:10px;
        }

        .menu a{
        color:white;
        text-decoration:none;
        display:block;
        padding:10px;
        border-radius:8px;
        }

        .menu a:hover{
        background:#f59e0b;
        color:black;
        }

        .content{
        flex:1;
        padding:20px;
        }

    </style>

</head>

<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <h4>Planificación y Gestión de Eventos</h4>
        <p>Organiza tus eventos</p>

        <ul class="menu">

            <li>
                <a asp-controller="Dashboard" asp-action="Index">
                    Dashboard
                </a>
            </li>

            @if (User.IsInRole("Organizador") || User.IsInRole("Admin"))
            {
                <li>
                    <a asp-controller="Eventoes" asp-action="Index">
                        Mis Eventos
                    </a>
                </li>

                <li>
                    <a asp-controller="Invitacions" asp-action="Index">
                        Invitados
                    </a>
                </li>
            }

            @* Usuarios y estadísticas solo para Admin *@
            @if (User.IsInRole("Admin"))
            {
                <li>
                    <a asp-controller="Usuarios" asp-action="Index">
                        Usuarios
                    </a>
                </li>

                <li>
                    <a asp-controller="Dashboard" asp-action="Index">
                        Estadísticas
                    </a>
                </li>
            }

        </ul>

        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <div class="small text-white mb-2">@User.Identity.Name</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-light">Cerrar sesión</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-light">Iniciar sesión</a>
            }
        </div>

    </div>

    <!-- CONTENIDO -->

    <div class="content">

        <main role="main">

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
