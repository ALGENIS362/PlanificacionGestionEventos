@model PlanificacionGestionEventos.Models.Evento

@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <h2>@Model.Nombre</h2>
            <p><strong>Fecha:</strong> @Model.Fecha.ToShortDateString() &nbsp; <strong>Hora:</strong> @Model.Hora</p>
            <p><strong>Lugar:</strong> @Model.Lugar</p>
            <p>@Model.Descripcion</p>
            <p><strong>Organizador:</strong> @Model.Organizador?.Email</p>
        </div>
        <div class="col-md-4">
            <h5>Galería</h5>
            @if (!string.IsNullOrWhiteSpace(Model.Images))
            {
                var imgs = Model.Images.Split(';').Where(s => !string.IsNullOrWhiteSpace(s)).ToList();
                <div id="carouselEvento" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i=0;i<imgs.Count;i++)
                        {
                            var img = imgs[i];
                            <div class="carousel-item @(i==0?"active":"")">
                                <img src="/uploads/@img" class="d-block w-100" alt="@Model.Nombre" style="max-height:300px; object-fit:cover;" />
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselEvento" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselEvento" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            }
            else
            {
                <p class="text-muted">No hay imágenes para este evento.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        @{ 
            var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
            int.TryParse(userIdClaim, out var currentUserId);
            var isOrganizer = (User.IsInRole("Organizador") && Model.OrganizadorId == currentUserId) || User.IsInRole("Admin");
        }

        @if (isOrganizer)
        {
            <a asp-action="Edit" asp-route-id="@Model?.EventoId" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        }
        else
        {
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Volver al Dashboard</a>
        }
    </div>
</div>
