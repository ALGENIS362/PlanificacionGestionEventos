@model PlanificacionGestionEventos.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        background-color: #0f172a;
        color: white; /* para que el texto se vea bien */
    }
    .dashboard-title {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .dashboard-sub {
        color: #6b7280;
        margin-bottom: 30px;
    }

    .card-dashboard {
        border: none;
        border-radius: 15px;
        padding: 10px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .card-dashboard:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.15);
    }

    .card-body h2 {
        font-size: 2.2rem;
        font-weight: bold;
    }

    .icon {
        font-size: 30px;
        opacity: 0.8;
    }
</style>

<h2 class="dashboard-title">📊 Dashboard</h2>
<p class="dashboard-sub">Resumen de tu actividad de eventos</p>

<div class="row">

    <!-- EVENTOS -->
    <div class="col-md-3">
        <div class="card card-dashboard text-white" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Eventos</h5>
                    <h2>@ViewBag.TotalEventos</h2>
                </div>
                <div class="icon">📅</div>
            </div>
        </div>
    </div>

    <!-- INVITACIONES -->
    <div class="col-md-3">
        <div class="card card-dashboard text-white" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Invitaciones</h5>
                    <h2>@ViewBag.TotalInvitaciones</h2>
                </div>
                <div class="icon">✉️</div>
            </div>
        </div>
    </div>

    <!-- RECHAZADOS -->
    <div class="col-md-3">
        <div class="card card-dashboard text-white" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Rechazados</h5>
                    <h2>@ViewBag.Rechazados</h2>
                </div>
                <div class="icon">❌</div>
            </div>
        </div>
    </div>

    <!-- CONFIRMADOS -->
    <div class="col-md-3">
        <div class="card card-dashboard text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5>Confirmados</h5>
                    <h2>@ViewBag.Confirmados</h2>
                </div>
                <div class="icon">✅</div>
            </div>
        </div>
    </div>

</div>