@model PlanificacionGestionEventos.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>
<p>Resumen de tu actividad de eventos</p>

<div class="row mt-4">

    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Usuarios</h5>
                <h2>@ViewBag.TotalUsuarios</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Eventos</h5>
                <h2>@ViewBag.TotalEventos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Invitaciones</h5>
                <h2>@ViewBag.TotalInvitaciones</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Confirmados</h5>
                <h2>@ViewBag.Confirmados</h2>
            </div>
        </div>
    </div>

</div>

@* Mostrar lista de eventos según rol/propiedad *@
@if (Model?.Eventos != null && Model.Eventos.Any())
{
    <h3 class="mt-4">Eventos</h3>
    <div class="row">
        @foreach (var ev in Model.Eventos)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@ev.Nombre</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Organizador: @ev.Organizador?.NombreCompleto</h6>
                        <p class="card-text">Fecha: @ev.Fecha.ToString("g")</p>
                        <p class="card-text">Lugar: @ev.Lugar</p>
                        <a asp-controller="Eventoes" asp-action="Details" asp-route-id="@ev.EventoId" class="btn btn-primary">Ver detalle</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="mt-4">No hay eventos para mostrar.</p>
}
