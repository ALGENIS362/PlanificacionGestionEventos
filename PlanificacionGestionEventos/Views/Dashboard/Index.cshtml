@model PlanificacionGestionEventos.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>
<p>Resumen de tu actividad de eventos</p>

<div class="row mt-4">

    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Usuarios</h5>
                <h2>@ViewBag.TotalUsuarios</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Eventos</h5>
                <h2>@ViewBag.TotalEventos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Invitaciones</h5>
                <h2>@ViewBag.TotalInvitaciones</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Confirmados</h5>
                <h2>@ViewBag.Confirmados</h2>
            </div>
        </div>
    </div>
</div>

<div class="events-section mt-4" style="clear:both;">
    @if (Model?.Eventos != null && Model.Eventos.Any())
    {
        <h3>Eventos</h3>
        <div class="row">
            @foreach (var ev in Model.Eventos)
            {
                <div class="col-md-6 mb-3">
                    @Html.Partial("~/Views/Eventoes/_EventoCardPartial.cshtml", ev)
                </div>
            }
        </div>
    }
    else if (User.IsInRole("Participante"))
    {
        <h3>Mis eventos</h3>
        <div class="text-center mt-3">
            <h5>No estás invitado a ningún evento</h5>
            <p class="text-muted">Pide a un organizador que te envíe una invitación.</p>
        </div>
    }
</div>
