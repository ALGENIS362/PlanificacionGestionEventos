@model PlanificacionGestionEventos.Models.Evento

@{
    var userIdClaim = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    int currentUserId = 0;
    if (!string.IsNullOrEmpty(userIdClaim))
    {
        currentUserId = int.Parse(userIdClaim);
    }
    var isParticipant = User?.Identity?.IsAuthenticated == true && User.IsInRole("Participante");
}

<div class="card-evento card p-2" data-state="@Model.Estado.ToString()" data-eventid="@Model.EventoId" data-images="@(Model.Images ?? "")" style="min-height:120px;">

    <div class="d-flex justify-content-between align-items-start mb-1">
        <div>
            <h5 class="mb-0" style="font-size:1rem">@Model.Nombre</h5>
            <div class="text-muted small" style="font-size:0.85rem">@Model.Fecha.ToShortDateString() · @Model.Hora</div>
        </div>
        <div>
            <span class="badge bg-secondary">@Model.Estado.ToString()</span>
        </div>
    </div>

    <p class="mb-0" style="font-size:0.9rem"><strong>Lugar:</strong> <span class="ev-lugar">@Model.Lugar</span></p>
    <p class="mb-0" style="font-size:0.9rem"><strong>Organizador:</strong> <span class="ev-organizador">@Model.Organizador?.NombreCompleto</span></p>
    <p class="descripcion text-truncate" style="max-height:3.6rem; overflow:hidden;">@Model.Descripcion</p>

    <div class="mt-3">
        <div class="d-flex gap-3 align-items-start">
            @* Preview image area *@
            <div style="flex:0 0 120px; height:90px; overflow:hidden; display:flex; align-items:center; justify-content:center; background:#f8f9fa; border-radius:6px;">
                @if (!string.IsNullOrWhiteSpace(Model.Images))
                {
                    var first = Model.Images.Split(';').FirstOrDefault();
                    if (!string.IsNullOrWhiteSpace(first))
                    {
                        <img src="/uploads/@first" class="img-fluid rounded" alt="@Model.Nombre" style="width:120px; height:90px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="text-muted small text-center">Imágenes no proporcionadas</div>
                    }
                }
                else
                {
                    <div class="text-muted small text-center">Imágenes no proporcionadas</div>
                }
            </div>

            @* Gallery button area (same size as preview) *@
            @if (!string.IsNullOrWhiteSpace(Model.Images))
            {
                <div style="flex:0 0 100px; height:90px; display:flex; align-items:center; justify-content:center;">
                    <button type="button" class="btn btn-outline-primary view-gallery-btn w-100 h-100" data-eventid="@Model.EventoId">Ver imágenes</button>
                </div>
            }
            else
            {
                <div style="flex:0 0 160px; height:120px;"></div>
            }
        </div>

        <div class="mt-2 d-flex gap-2">
            @* Para participantes, mostrar botón de responder *@
            @if (isParticipant)
            {
                <a asp-controller="Invitacions" asp-action="Respond" asp-route-eventoId="@Model.EventoId" class="btn btn-primary btn-sm">
                    📧 Responder Invitación
                </a>
            }
            @* Mostrar botón 'Invitados' sólo al organizador o admin *@
            @if (User?.Identity?.IsAuthenticated == true && (User.IsInRole("Organizador") && Model.OrganizadorId == currentUserId || User.IsInRole("Admin")))
            {
                <button type="button" class="btn btn-outline-secondary btn-sm invitados-btn" data-eventid="@Model.EventoId">Invitados</button>
            }
            @if (User?.Identity?.IsAuthenticated == true
                        && User.IsInRole("Organizador")
                        && Model != null
                        && Model.OrganizadorId == currentUserId)
            {
                <button type="button" class="btn btn-success btn-sm edit-event-btn" data-eventid="@Model.EventoId">
                    ✏ Editar
                </button>

                <form asp-action="Delete" asp-route-id="@Model.EventoId" method="post" class="d-inline"
                      onsubmit="return confirm('¿Confirmas que deseas eliminar este evento?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm shadow-sm">
                        🗑 Eliminar
                    </button>
                </form>
            }
        </div>
    </div>
</div>
